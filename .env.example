# StoryMagic Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE & SUPABASE
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# ===========================================
# CLIENT ENVIRONMENT (for Vite)
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ===========================================
# AI & TTS SERVICES
# ===========================================
# OpenRouter (Primary AI service)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ElevenLabs (Premium TTS - optional but recommended)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI (Fallback TTS - optional)
OPENAI_API_KEY=sk-your_openai_key_here

# ===========================================
# LEMON SQUEEZY PAYMENT INTEGRATION
# ===========================================
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id_here
LEMONSQUEEZY_VARIANT_ID=your_variant_id_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Client-side Lemon Squeezy (for frontend)
VITE_LEMONSQUEEZY_STORE_ID=your_store_id_here
VITE_LEMONSQUEEZY_PRODUCT_ID=your_product_id_here
VITE_LEMONSQUEEZY_VARIANT_ID=your_variant_id_here
VITE_LEMONSQUEEZY_PUBLIC_KEY=your_public_key_here

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
NODE_ENV=production
CLIENT_URL=https://your-domain.com

# ===========================================
# AUDIO PROCESSING
# ===========================================
# Background music settings
ENABLE_BACKGROUND_MUSIC=true
AUDIO_QUALITY=high
MAX_AUDIO_DURATION=600
CUSTOM_AUDIO_PATH=./assets/audio/backgrounds

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_OPENROUTER=true
ENABLE_ELEVENLABS=true
ENABLE_OPENAI=true

# ===========================================
# SECURITY
# ===========================================
SESSION_SECRET=your_session_secret_here

# Frontend (client-side) Supabase configuration
VITE_SUPABASE_URL=your-project-url           # Example: https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key        # Public anon key (starts with eyJ...)

# Backend (server-side) configuration
SUPABASE_URL=${VITE_SUPABASE_URL}           # Same as frontend URL
SUPABASE_SERVICE_ROLE_KEY=service-role-key   # Secret key with full access
DATABASE_URL=postgres-connection-string       # Postgres connection string from Supabase dashboard

# Environment
NODE_ENV=development

# Other existing configuration
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
