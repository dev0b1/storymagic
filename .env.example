# Frontend (client-side) Supabase configuration
VITE_SUPABASE_URL=your-project-url           # Example: https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key        # Public anon key (starts with eyJ...)

# Backend (server-side) configuration
SUPABASE_URL=${VITE_SUPABASE_URL}           # Same as frontend URL
SUPABASE_SERVICE_ROLE_KEY=service-role-key   # Secret key with full access
DATABASE_URL=postgres-connection-string       # Postgres connection string from Supabase dashboard

# Environment
NODE_ENV=development

# Other existing configuration
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
